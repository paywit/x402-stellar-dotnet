<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>x402-stellar-dotnet</PackageId>
    <Version>0.1.0</Version>
    <Authors>Paywit</Authors>
    <Description>The first .NET SDK for the x402 payment protocol on Stellar. Parse/generate x402 payment headers, build 402 responses, and communicate with facilitators.</Description>
    <PackageTags>x402;stellar;payments;ai-agents;usdc;soroban</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/paywit/x402-stellar-dotnet</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

</Project>
